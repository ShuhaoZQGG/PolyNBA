# PolyNBA Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED FOR LIVE TRADING
# =============================================================================

# Your Ethereum private key for signing Polymarket transactions
# Get this from your wallet (MetaMask: Account Details > Export Private Key)
# WARNING: Never share this key or commit it to version control!
POLYMARKET_PRIVATE_KEY=0x...

# =============================================================================
# OPTIONAL - AI ANALYSIS
# =============================================================================

# Anthropic API key for Claude-powered game analysis
# Get from: https://console.anthropic.com/
# If not set, Claude analysis will be disabled
ANTHROPIC_API_KEY=sk-ant-...

# =============================================================================
# OPTIONAL - ADVANCED CONFIGURATION
# =============================================================================

# Polygon RPC endpoint (default: https://polygon-rpc.com)
# For better reliability, use Alchemy or Infura
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Chain ID (default: 137 for Polygon mainnet)
# CHAIN_ID=137

# Polymarket CLOB API host (default: https://clob.polymarket.com)
# POLYMARKET_HOST=https://clob.polymarket.com

# =============================================================================
# OPTIONAL - PAPER TRADING (no keys needed)
# =============================================================================

# To run in paper trading mode, no environment variables are required.
# Just run: python -m polynba --mode paper
